# Copy to .env and adjust if your export lives somewhere else.
APPLE_EXPORT_DIR=apple_health_export
APPLE_EXPORT_XML=apple_health_export/export.xml
WORKOUT_ROUTES_DIR=apple_health_export/workout-routes
OUTPUT_DIR=garmin_gpx_output

GARMIN_CREATOR=Garmin Connect
OUTPUT_PREFIX=activity
MODE=gpx
LIMIT=
HEART_RATE_SOURCE=record
FUZZY_MATCH_SECONDS=0
DEBUG_XLSX=false
OVERWRITE_EXISTING=true

# Garmin import helper
GARMIN_IMPORT_URL=https://connect.garmin.com/app/import-data
GARMIN_IMPORT_FOLDER=garmin_gpx_output
GARMIN_IMPORT_FILE_PATTERN=*.gpx
GARMIN_IMPORT_BATCH_SIZE=10
GARMIN_IMPORT_STAGING_DIR=.garmin_import_current_batch
GARMIN_IMPORT_STATE_FILE=.garmin_import_state.json
GARMIN_IMPORT_OPEN_STAGING_FOLDER=false
GARMIN_IMPORT_RESET_PROGRESS=false
GARMIN_IMPORT_AUTOMATE_DIALOG=true
