# Copy to .env and adjust if your export lives somewhere else.
APPLE_EXPORT_DIR=apple_health_export
APPLE_EXPORT_XML=apple_health_export/export.xml
WORKOUT_ROUTES_DIR=apple_health_export/workout-routes
OUTPUT_DIR=garmin_gpx_output

GARMIN_CREATOR=Garmin Connect
OUTPUT_PREFIX=activity
MODE=gpx
LIMIT=
HEART_RATE_SOURCE=record
FUZZY_MATCH_SECONDS=0
DEBUG_XLSX=false
OVERWRITE_EXISTING=true
